{
  "entities": {
    "User": {
      "title": "User",
      "description": "A staff member or admin user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "name": { "type": "string", "description": "Full name of the user." },
        "email": { "type": "string", "format": "email", "description": "Email address." },
        "role": { "type": "string", "enum": ["admin", "editor", "viewer"], "description": "Access level." },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Pending"], "description": "Account status." },
        "avatar": { "type": "string", "description": "URL to the profile picture." },
        "designation": { "type": "string", "description": "User job title or designation." },
        "invitedDate": { "type": "string", "description": "Date the user was invited." },
        "id": { "type": "string", "description": "Local ID field used in the application." }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "Task": {
      "title": "Task",
      "description": "A task assigned to a client or user.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Task title." },
        "clientId": { "type": "string", "description": "Associated client ID." },
        "clientName": { "type": "string", "description": "Associated client name." },
        "status": { 
          "type": "string", 
          "enum": [
            "Listing To Do", 
            "Design To Do", 
            "Design Confirm Request", 
            "Confirm Request Final", 
            "Confirmed", 
            "Listing Completed",
            "Completed", 
            "In Progress", 
            "Not Started"
          ], 
          "description": "Current status." 
        },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"], "description": "Task priority." },
        "dueDate": { "type": "string", "description": "Due date." },
        "subtasks": {
          "type": "object",
          "properties": {
            "completed": { "type": "number" },
            "total": { "type": "number" }
          }
        },
        "assignedTo": { "type": "string", "description": "UID of the assigned user." },
        "assignedToName": { "type": "string", "description": "Name of the assigned user." },
        "createdAt": { "type": "string", "description": "Creation timestamp." },
        "images": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of image URLs."
        },
        "comments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "userPhoto": { "type": "string" },
              "createdAt": { "type": "string" }
            },
            "required": ["id", "text", "userId", "userName", "createdAt"]
          },
          "description": "List of task comments."
        }
      },
      "required": ["title", "status", "priority", "dueDate"]
    },
    "Client": {
      "title": "Client",
      "description": "A client organization.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Client name." },
        "industry": { "type": "string", "description": "Industry sector." },
        "projects": { "type": "number", "description": "Number of active projects." },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "website": { "type": "string" }
      },
      "required": ["name"]
    },
    "Invite": {
      "title": "Invite",
      "description": "A pending staff invitation.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "editor", "viewer"] },
        "invitedBy": { "type": "string", "description": "UID of the inviter." },
        "timestamp": { "type": "string", "description": "Time of invitation." }
      },
      "required": ["email", "role", "timestamp"]
    },
    "TimeEntry": {
      "title": "TimeEntry",
      "description": "A log of time worked.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "taskId": { "type": "string" },
        "taskTitle": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "duration": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["userId", "clientId", "startTime", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles." },
    "/tasks/{taskId}": { "schema": "Task", "description": "Global tasks list." },
    "/clients/{clientId}": { "schema": "Client", "description": "Client database." },
    "/invites/{inviteId}": { "schema": "Invite", "description": "Pending invitations." },
    "/timeEntries/{entryId}": { "schema": "TimeEntry", "description": "Time logs." }
  }
}
